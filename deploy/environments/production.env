# M3 production environment for OKE crawler-executor.
# This file intentionally contains no real credentials.

ENVIRONMENT=production

# Kubernetes / OKE placement.
M3_K8S_NAMESPACE=crawler-executor
M3_DAEMONSET_NAME=crawler-executor
M3_LABEL_SELECTOR=app.kubernetes.io/name=crawler-executor,app.kubernetes.io/component=fetch-worker
M3_NODE_POOL_NAME=scrapy-node-pool
M3_SUBNET_NAME=subnetCollection
M3_NODE_SELECTOR_KEY=scrapy-egress
M3_NODE_SELECTOR_VALUE=true
M3_NODE_LABEL=scrapy-egress=true
M3_NODE_TAINT_ENABLED=false
M3_NODE_TAINT=
M3_EXPECTED_MIN_PODS=2

# Host network IP pool.
CRAWL_INTERFACE=enp0s5
M3_CRAWL_INTERFACE=enp0s5
M3_IP_POOL_EXPECTED_RANGE=60-70
M3_IP_POOL_MIN_EXPECTED=60
EXCLUDED_LOCAL_IPS=
LOCAL_IP_POOL=
IP_SELECTION_STRATEGY=STICKY_BY_HOST
IP_FAILURE_THRESHOLD=5
IP_FAILURE_WINDOW_SECONDS=300
IP_COOLDOWN_SECONDS=1800

# Redis Streams fetch queue.
FETCH_QUEUE_BACKEND=redis_streams
FETCH_QUEUE_STREAM=crawl:tasks
FETCH_QUEUE_GROUP=crawler-executor
FETCH_QUEUE_CONSUMER_TEMPLATE='${NODE_NAME}-${POD_NAME}'
FETCH_QUEUE_READ_COUNT=10
FETCH_QUEUE_BLOCK_MS=1000
FETCH_QUEUE_MAX_DELIVERIES=3
FETCH_QUEUE_CLAIM_MIN_IDLE_MS=60000
FETCH_QUEUE_SHUTDOWN_DRAIN_SECONDS=25
FETCH_QUEUE_MAX_MESSAGES=0

# Scrapy runtime.
CONCURRENT_REQUESTS=64
CONCURRENT_REQUESTS_PER_DOMAIN=4
DOWNLOAD_DELAY=0.1
DOWNLOAD_TIMEOUT=30
RETRY_ENABLED=true
RETRY_TIMES=2
FORCE_CLOSE_CONNECTIONS=true
LOG_LEVEL=INFO

# Persistence and object storage.
ENABLE_P1_PERSISTENCE=true
OBJECT_STORAGE_PROVIDER=oci
OCI_AUTH_MODE=instance_principal
OCI_OBJECT_STORAGE_BUCKET=clawer_bucket_prod
OCI_OBJECT_STORAGE_NAMESPACE=axfwvgxlpupm
OCI_OBJECT_STORAGE_REGION=us-phoenix-1
OCI_OBJECT_STORAGE_ENDPOINT=https://objectstorage.us-phoenix-1.oraclecloud.com
CONTENT_COMPRESSION=gzip

# Kafka / OCI Streaming with Kafka. Credentials must be stored in K8s Secret.
KAFKA_BOOTSTRAP_SERVERS=bootstrap-clstr-7llai78p4xnlukju.kafka.us-phoenix-1.oci.oraclecloud.com:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SSL_CA_LOCATION=/etc/pki/tls/certs/ca-bundle.crt
KAFKA_TOPIC_CRAWL_ATTEMPT=crawler.crawl-attempt.v1
KAFKA_BATCH_SIZE=100
KAFKA_PRODUCER_RETRIES=3
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_DELIVERY_TIMEOUT_MS=120000
KAFKA_FLUSH_TIMEOUT_MS=130000

# Secret values are placeholders. Create real K8s Secrets instead of committing values.
FETCH_QUEUE_REDIS_URL=CHANGE_ME_REDIS_URL
REDIS_URL=CHANGE_ME_REDIS_URL
KAFKA_USERNAME=CHANGE_ME_KAFKA_USERNAME
KAFKA_PASSWORD=CHANGE_ME_KAFKA_PASSWORD

# Metrics, health, debug, and pause controls.
PROMETHEUS_PORT=9410
HEALTH_PORT=9411
READINESS_MAX_HEARTBEAT_AGE_SECONDS=30
CRAWLER_PAUSED=false
CRAWLER_PAUSE_FILE=/etc/crawler/runtime/crawler_paused
CRAWLER_PAUSE_POLL_SECONDS=5
CRAWLER_DEBUG_MODE=false
DEBUG_FETCH_QUEUE_STREAM_TEMPLATE='crawl:tasks:debug:{node_name}'
DEBUG_FETCH_QUEUE_GROUP_TEMPLATE='crawler-executor-debug:{node_name}'
DEBUG_FETCH_QUEUE_CONSUMER_TEMPLATE='${NODE_NAME}-${POD_NAME}-debug'
DEBUG_ATTEMPT_TIER=debug
