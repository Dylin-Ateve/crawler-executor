# P0 验证环境变量示例。
# 使用前请复制为本机环境文件，按真实节点信息修改。

# Redis 连接串。P0 需要 Redis 记录 Host/IP 失败计数和黑名单 TTL。
# 真实环境必须使用用户名和密码认证。
# 格式：redis://<username>:<url-encoded-password>@<host>:<port>/<db>
# 如果密码包含 @、:、/、#、%、&、! 等特殊字符，必须先做 URL encode。
# 端口约定：使用 TLS 时采用 6379；不使用 TLS 时采用 7379。
# 建议整条 REDIS_URL 用单引号包裹，避免 shell 解释特殊字符。
REDIS_URL='redis://crawler-executor:CHANGE_ME_URL_ENCODED@redis-host:6379/0'
REDIS_KEY_PREFIX=crawler-executor
VALKEY_CLI=valkey-cli

# 目标 Linux 节点网卡名。暂按 ens3；如果真实节点不同，改成实际网卡。
CRAWL_INTERFACE=ens3

# 管理 IP 或不希望用于爬取出口的 IP。支持多个，用英文逗号分隔。
EXCLUDED_LOCAL_IPS=10.0.12.196

# P0 正常验证使用 STICKY_BY_HOST；诊断 IP 轮换时可改为 ROUND_ROBIN。
IP_SELECTION_STRATEGY=STICKY_BY_HOST

# 黑名单阈值。403/429/503 连续 5 次进入冷却；captcha 单次命中进入冷却。
IP_FAILURE_THRESHOLD=5
IP_FAILURE_WINDOW_SECONDS=300
IP_COOLDOWN_SECONDS=1800

# P0 保守起步并发。后续按观测逐步调优。
CONCURRENT_REQUESTS=32
CONCURRENT_REQUESTS_PER_DOMAIN=2
DOWNLOAD_DELAY=0.1
DOWNLOAD_TIMEOUT=30
RETRY_ENABLED=true
RETRY_TIMES=2

# Prometheus 指标端口。
PROMETHEUS_PORT=9410

# P0 多出口验证默认关闭 HTTP keep-alive，避免连接复用掩盖 bindaddress 效果。
FORCE_CLOSE_CONNECTIONS=true

# 24 小时稳定性测试时长。短测可改为 10m、1h。
P0_SOAK_DURATION=24h

# 出口验证诊断参数。需要覆盖更多出口 IP 时，可调大 repeat 或 max pages。
P0_VALIDATION_REPEAT=1
P0_VALIDATION_MAX_PAGES=0
