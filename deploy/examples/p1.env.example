# P1 验证环境变量示例。
# 使用前请复制为本机环境文件，按真实节点信息修改。

ENABLE_P1_PERSISTENCE=true

# OCI Object Storage。P1 使用 OCI SDK 接入。
OBJECT_STORAGE_PROVIDER=oci
OCI_OBJECT_STORAGE_BUCKET=clawer_content_staging
OCI_OBJECT_STORAGE_NAMESPACE=axfwvgxlpupm
OCI_OBJECT_STORAGE_REGION=us-phoenix-1
OCI_OBJECT_STORAGE_ENDPOINT=https://objectstorage.us-phoenix-1.oraclecloud.com

# 开发环境使用 api_key，生产环境使用 instance_principal。
# api_key 模式依赖 OCI_CONFIG_FILE 与 OCI_PROFILE。
OCI_AUTH_MODE=api_key
OCI_CONFIG_FILE="${HOME}/.oci/config"
OCI_PROFILE=DEFAULT

CONTENT_COMPRESSION=gzip

# Kafka。用户名和密码通过环境变量或 secret 注入，不提交真实值。
KAFKA_BOOTSTRAP_SERVERS=bootstrap-clstr-hcpqnx0ycdc2ds5o.kafka.us-phoenix-1.oci.oraclecloud.com:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_USERNAME=CHANGE_ME
KAFKA_PASSWORD=CHANGE_ME
KAFKA_SSL_CA_LOCATION=/etc/pki/tls/certs/ca-bundle.crt
KAFKA_BATCH_SIZE=100
KAFKA_TOPIC_PAGE_METADATA=crawler.page-metadata.v1
KAFKA_PRODUCER_RETRIES=3
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_DELIVERY_TIMEOUT_MS=120000

# P1 验证运行参数。
P1_VALIDATION_REPEAT=1
P1_VALIDATION_MAX_PAGES=0
